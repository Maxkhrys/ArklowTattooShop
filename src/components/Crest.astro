---
// Stylised SVG recreation of the Arklow Tattoo Studio raven crest.
// [PLACEHOLDER: real logo file — supplied separately. Swap this component's
// SVG for /public/brand/logo.png when the client's file is dropped in.]
interface Props {
  class?: string;
  showMachines?: boolean;
  [key: string]: unknown;
}
const { class: className = '', showMachines = true, ...rest } = Astro.props;
---

<svg
  class={className}
  {...rest}
  viewBox="0 0 400 340"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Arklow Tattoo Studio raven crest"
>
  <!-- Spiked crown / halo -->
  <g class="crest-halo" stroke="#0a0a0a" stroke-width="5" stroke-linecap="round">
    <circle cx="200" cy="86" r="34" fill="none" stroke="#0a0a0a" stroke-width="6" />
    <line x1="200" y1="34" x2="200" y2="12" />
    <line x1="172" y1="42" x2="160" y2="24" />
    <line x1="228" y1="42" x2="240" y2="24" />
    <line x1="150" y1="62" x2="132" y2="50" />
    <line x1="250" y1="62" x2="268" y2="50" />
    <line x1="140" y1="88" x2="120" y2="84" />
    <line x1="260" y1="88" x2="280" y2="84" />
  </g>

  <!-- Wings: fanned primary feathers, right wing drawn, left mirrored -->
  <g class="crest-wing crest-wing-right">
    <g stroke="#0a0a0a" stroke-width="13" stroke-linecap="round">
      <line x1="216" y1="132" x2="348" y2="56" />
      <line x1="216" y1="138" x2="340" y2="94" />
      <line x1="216" y1="144" x2="322" y2="130" />
      <line x1="216" y1="150" x2="296" y2="160" />
      <line x1="216" y1="156" x2="264" y2="182" />
      <line x1="214" y1="162" x2="236" y2="196" />
    </g>
    <path d="M204 120 C 230 112 246 126 242 148 C 238 168 222 176 206 170 Z" fill="#0a0a0a" />
  </g>
  <g class="crest-wing crest-wing-left" transform="translate(400,0) scale(-1,1)">
    <g stroke="#0a0a0a" stroke-width="13" stroke-linecap="round">
      <line x1="216" y1="132" x2="348" y2="56" />
      <line x1="216" y1="138" x2="340" y2="94" />
      <line x1="216" y1="144" x2="322" y2="130" />
      <line x1="216" y1="150" x2="296" y2="160" />
      <line x1="216" y1="156" x2="264" y2="182" />
      <line x1="214" y1="162" x2="236" y2="196" />
    </g>
    <path d="M204 120 C 230 112 246 126 242 148 C 238 168 222 176 206 170 Z" fill="#0a0a0a" />
  </g>

  <!-- Raven body, head and tail -->
  <g fill="#0a0a0a">
    <path d="M200 96
             C 190 96, 182 104, 182 116
             C 182 124, 186 130, 192 134
             L 186 142
             C 180 154, 178 168, 182 182
             C 186 198, 194 210, 200 216
             C 206 210, 214 198, 218 182
             C 222 168, 220 154, 214 142
             L 208 134
             C 214 130, 218 124, 218 116
             C 218 104, 210 96, 200 96 Z" />
    <!-- beak -->
    <path d="M196 118 L 200 130 L 204 118 L 200 121 Z" fill="#050505" />
    <!-- tail feathers -->
    <path d="M200 214
             C 192 232, 188 252, 190 274
             L 200 258 L 210 274
             C 212 252, 208 232, 200 214 Z" />
    <path d="M200 224 C 186 240, 178 258, 176 278 L 190 262 Z" opacity="0.9" />
    <path d="M200 224 C 214 240, 222 258, 224 278 L 210 262 Z" opacity="0.9" />
  </g>

  <!-- Eye glint -->
  <circle cx="196" cy="112" r="2" fill="#a566ec" opacity="0.9" />

  {showMachines && (
    <!-- Crossed tattoo machines -->
    <g class="crest-machines" stroke="#a566ec" stroke-width="3" fill="#0a0a0a" stroke-linejoin="round">
      <g transform="rotate(38 200 300)">
        <rect x="168" y="292" width="40" height="16" rx="3" />
        <rect x="176" y="278" width="18" height="16" rx="3" />
        <line x1="208" y1="300" x2="238" y2="300" />
        <path d="M238 297 L 246 300 L 238 303 Z" fill="#a566ec" stroke="none" />
      </g>
      <g transform="rotate(-38 200 300)">
        <rect x="192" y="292" width="40" height="16" rx="3" />
        <rect x="206" y="278" width="18" height="16" rx="3" />
        <line x1="192" y1="300" x2="162" y2="300" />
        <path d="M162 297 L 154 300 L 162 303 Z" fill="#a566ec" stroke="none" />
      </g>
    </g>
  )}
</svg>
