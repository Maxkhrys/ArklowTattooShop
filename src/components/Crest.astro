---
// Real Arklow Tattoo Studio raven crest, supplied by the client rep.
interface Props {
  class?: string;
  showMachines?: boolean;
  [key: string]: unknown;
}
const { class: className = '', showMachines: _showMachines = true, ...rest } = Astro.props;
---

<img
  src="/brand/logo.png"
  alt="Arklow Tattoo Studio raven crest"
  class={`object-contain ${className}`}
  {...rest}
/>
