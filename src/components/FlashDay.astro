---
// Time-sensitive launch promo. Swap the copy below for future events —
// everything event-specific lives in this one component.
---

<section id="flash" class="relative overflow-hidden py-20 sm:py-24" aria-label="Grand Opening Flash Day">
  <!-- Louder register: flyer energy, contained to this section -->
  <div class="absolute inset-0" style="background: linear-gradient(160deg, #1c0836 0%, #0d0a12 55%, #050505 100%);" aria-hidden="true"></div>
  <!-- Lightning bolts -->
  <svg class="absolute -left-6 top-8 h-40 w-40 rotate-[-14deg] opacity-70" viewBox="0 0 100 100" aria-hidden="true">
    <path d="M55 4 L28 52 L46 52 L38 96 L74 40 L54 40 Z" fill="none" stroke="#a566ec" stroke-width="4" stroke-linejoin="round" style="filter: drop-shadow(0 0 10px #7c2fd6);" />
  </svg>
  <svg class="absolute -right-4 bottom-6 h-32 w-32 rotate-[12deg] opacity-70" viewBox="0 0 100 100" aria-hidden="true">
    <path d="M55 4 L28 52 L46 52 L38 96 L74 40 L54 40 Z" fill="none" stroke="#a566ec" stroke-width="4" stroke-linejoin="round" style="filter: drop-shadow(0 0 10px #7c2fd6);" />
  </svg>

  <div class="relative mx-auto max-w-4xl px-5 text-center">
    <p class="flash-pop font-flash text-sm uppercase tracking-[0.35em] text-violet-bright flash-flicker">
      ⚡ Grand Opening ⚡
    </p>
    <h2 class="flash-pop mt-4 font-flash text-4xl uppercase leading-tight text-bone flash-shadow sm:text-6xl">
      Flash Day
    </h2>
    <p class="flash-pop mt-3 font-flash text-lg uppercase tracking-widest text-violet-bright sm:text-2xl">
      Saturday July 4th · 10am–6pm
    </p>

    <div class="mt-10 flex flex-wrap items-stretch justify-center gap-4 sm:gap-6">
      <div class="flash-pop w-40 -rotate-2 rounded-md border-2 border-violet-bright bg-ink/70 p-5 sm:w-48" style="box-shadow: 4px 4px 0 #2b0a52, 0 0 24px rgb(124 47 214 / 0.5);">
        <p class="font-flash text-3xl text-bone sm:text-4xl">€70</p>
        <p class="mt-1 text-xs uppercase tracking-[0.2em] text-bone-dim">Flash tattoos from</p>
      </div>
      <div class="flash-pop w-40 rotate-2 rounded-md border-2 border-violet-bright bg-ink/70 p-5 sm:w-48" style="box-shadow: 4px 4px 0 #2b0a52, 0 0 24px rgb(124 47 214 / 0.5);">
        <p class="font-flash text-3xl text-bone sm:text-4xl">€20</p>
        <p class="mt-1 text-xs uppercase tracking-[0.2em] text-bone-dim">All piercings</p>
      </div>
    </div>

    <p class="flash-pop mt-8 text-sm text-bone-dim">
      Piercer on site with <span class="font-semibold text-violet-bright">Inky Tattoo</span> · 7 Bridge Street, Arklow · Walk-ins welcome
    </p>
    <div class="flash-pop mt-6">
      <a href="#booking" class="btn-crest border-violet-bright">Claim your slot</a>
    </div>
  </div>
</section>
