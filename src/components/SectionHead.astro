---
interface Props {
  kicker: string;
  title: string;
  id?: string;
}
const { kicker, title, id } = Astro.props;
---

<div class="reveal mx-auto mb-14 max-w-2xl px-5 text-center" id={id}>
  <p class="text-xs uppercase tracking-[0.35em] text-violet-bright">{kicker}</p>
  <h2 class="mt-3 font-display text-4xl tracking-wide glow-text-soft sm:text-5xl">{title}</h2>
  <div class="divider-glow mx-auto mt-6 w-40"></div>
</div>
